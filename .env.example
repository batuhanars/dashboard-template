# true → mock handler'lar aktif (backend gerekmez)
# false → VITE_API_BASE_URL ile gerçek API kullanılır
VITE_USE_MOCKS=true

# Gerçek API base URL (VITE_USE_MOCKS=false iken gerekli)
# Örnek: https://api.example.com
VITE_API_BASE_URL=

# Sidebar başlığında ve sekme adında görünen uygulama adı
VITE_APP_NAME=Dashboard
